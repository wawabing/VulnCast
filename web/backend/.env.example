# Copy this file to .env and fill in real values.
# The .env file is git-ignored — never commit real secrets.

PORT=3000

# NVD API keys (comma-separated for rate-limit rotation). Get one at
# https://nvd.nist.gov/developers/request-an-api-key. Without a key the NVD
# rate limit is 5 requests per 30s. With a key it's 50 requests per 30s.
NVD_API_KEYS=your-nvd-key-1,your-nvd-key-2

# AWS Cognito (OpenID Connect) — create a User Pool + App Client in the AWS console.
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_APP_CLIENT_SECRET=your-app-client-secret
COGNITO_CALLBACK_URL=http://localhost:3000/auth/callback
COGNITO_LOGOUT_URL=http://localhost:3000/login
COGNITO_DOMAIN=https://<your-cognito-domain>.auth.<region>.amazoncognito.com

# Express session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# AWS credentials for S3 + DynamoDB access (use an IAM user scoped to just these services).
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# S3 bucket where user schemas, enriched schemas, and SBOM manifests are stored.
S3_BUCKET_NAME=your-s3-bucket-name

# Name of the deployed version-level forecast Lambda (see ../forecast-service).
FORECAST_LAMBDA_NAME=cpe-forecast-service
