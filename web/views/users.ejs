<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Users - VulnCast</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.css" rel="stylesheet">
</head>
<body>
  <div class="dashboard-container">
    <%- include('partials/sidebar', { activeNav: 'users' }) %>

    <!-- Main Content -->
    <main class="dashboard-main">
      <header class="dashboard-header">
        <h1>Users Management</h1>
        <div class="header-actions">
          <span class="last-updated" id="lastUpdated">Loading...</span>
          <button class="refresh-btn" id="refreshBtn">
            <i class="fas fa-sync-alt"></i>
          </button>
        </div>
      </header>

      <!-- Users Table -->
      <div class="table-container">
        <div class="table-header">
          <h2><i class="fas fa-users"></i> All Users</h2>
          <div class="table-stats" id="userStats">
            <span class="stat-badge">Loading...</span>
          </div>
        </div>
        
        <div class="table-wrapper">
          <table class="data-table" id="usersTable">
            <thead>
              <tr>
                <th>Username</th>
                <th>Email</th>
                <th>User ID</th>
                <th>Organization</th>
                <th>Devices</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="usersTableBody">
              <tr>
                <td colspan="6" class="loading-row">Loading user data...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <script src="/js/users.js"></script>
</body>
</html>